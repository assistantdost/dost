{
	"main": "dist-electron/main.js",
	"name": "mcp-desktop-client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main.js\"",
		"build:react": "vite build",
		"build:electron": "vite build --config electron/vite.config.js",
		"electron-builder": "electron-builder --win nsis",
		"build": "npm run build:react && npm run build:electron && npm run electron-builder",
		"preview": "vite preview",
		"lint": "eslint ."
	},
	"build": {
		"appId": "com.mcp.desktopclient",
		"productName": "MCP Desktop Client",
		"directories": {
			"buildResources": "build",
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"electron/**/*"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			]
		}
	},
	"dependencies": {
		"@ai-sdk/groq": "^2.0.19",
		"@ai-sdk/mcp": "^0.0.12",
		"@ai-sdk/react": "^2.0.45",
		"@icons-pack/react-simple-icons": "^13.8.0",
		"@modelcontextprotocol/sdk": "^1.18.1",
		"@orama/orama": "^3.1.18",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@radix-ui/react-use-controllable-state": "^1.2.2",
		"@react-oauth/google": "^0.12.2",
		"@tailwindcss/vite": "^4.1.13",
		"@tanstack/react-query": "^5.90.20",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@xenova/transformers": "^2.17.2",
		"ai": "^5.0.115",
		"body-parser": "^2.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cors": "^2.8.5",
		"d3": "^7.9.0",
		"d3-graphviz": "^5.6.0",
		"dotenv": "^17.2.2",
		"electron-store": "^11.0.2",
		"express": "^5.1.0",
		"gpt-tokenizer": "^3.4.0",
		"harden-react-markdown": "^1.1.7",
		"katex": "^0.16.27",
		"lucide-react": "^0.544.0",
		"mermaid": "^11.12.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.10.1",
		"react-syntax-highlighter": "^16.1.0",
		"react-window": "^2.1.1",
		"rehype-katex": "^7.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"shiki": "^3.20.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.13",
		"use-stick-to-bottom": "^1.1.1",
		"viz.js": "^2.1.2",
		"zod": "^3.25.76",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@eslint/js": "^9.33.0",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"concurrently": "^9.2.1",
		"cross-env": "^10.0.0",
		"electron": "^38.1.0",
		"electron-builder": "^26.8.1",
		"eslint": "^9.33.0",
		"eslint-import-resolver-alias": "^1.1.2",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"globals": "^16.3.0",
		"tw-animate-css": "^1.4.0",
		"vite": "^7.1.2",
		"wait-on": "^8.0.5"
	}
}
