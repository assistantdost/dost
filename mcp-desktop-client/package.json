{
	"name": "dost",
	"private": true,
	"version": "1.0.0",
	"scripts": {
		"install:all": "npm install && cd client && npm install && cd ../electron && npm install",
		"dev": "concurrently \"npm run dev:client\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
		"dev:client": "cd client && npm run dev",
		"dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main.js",
		"build": "cd client && npm run build",
		"dist:dir": "npm run build && electron-builder --win dir",
		"dist": "npm run build && electron-builder --win nsis"
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"cross-env": "^10.0.0",
		"dotenv": "^16.4.5",
		"electron": "^38.1.0",
		"electron-builder": "^26.8.1",
		"wait-on": "^8.0.5"
	},
	"build": {
		"appId": "com.dost.app",
		"productName": "Dost",
		"asar": true,
		"compression": "store",
		"directories": {
			"app": "electron",
			"buildResources": "build",
			"output": "release"
		},
		"files": [
			"**/*",
			"!**/.git/**",
			"!**/*.map",
			"!node_modules/.cache/**",
			{
				"from": "../client/dist",
				"to": "dist"
			}
		],
		"extraResources": [
			{
				"from": "resources",
				"to": ".",
				"filter": [
					"**/*"
				]
			},
			{
				"from": ".env",
				"to": ".env"
			}
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"executableName": "Dost"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		}
	}
}
